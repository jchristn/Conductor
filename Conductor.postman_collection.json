          "name": "Login with Credential",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"TenantId\": \"{{tenantId}}\",\n  \"Email\": \"{{email}}\",\n  \"Password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1.0/auth/login/credential",
              "host": ["{{baseUrl}}"],
              "path": ["v1.0", "auth", "login", "credential"]
            }
          }
        },
        {
          "name": "Login with API Key",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
