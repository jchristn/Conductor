              "raw": "{{baseUrl}}/v1.0/requesthistory/{{requestHistoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1.0", "requesthistory", "{{requestHistoryId}}"]
            },
            "description": "Delete a single request history entry by ID."
          }
        },
        {
          "name": "Bulk Delete Request History",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/v1.0/requesthistory/bulk",
              "host": ["{{baseUrl}}"],
