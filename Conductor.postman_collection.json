    {
      "name": "Request History",
      "item": [
        {
          "name": "Search Request History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1.0/requesthistory?page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["v1.0", "requesthistory"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" },
                { "key": "vmrGuid", "value": "", "disabled": true },
                { "key": "endpointGuid", "value": "", "disabled": true },
                { "key": "sourceIp", "value": "", "disabled": true },
                { "key": "httpStatus", "value": "", "disabled": true }
              ]
            },
            "description": "Search request history entries with pagination and filtering."
          }
        },
        {
          "name": "Get Request History Summary",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1.0/requesthistory/summary?interval=hour",
              "host": ["{{baseUrl}}"],
              "path": ["v1.0", "requesthistory", "summary"],
              "query": [
                { "key": "startUtc", "value": "", "disabled": true, "description": "Start of time range (UTC, ISO 8601). Default: 1 hour ago" },
                { "key": "endUtc", "value": "", "disabled": true, "description": "End of time range (UTC, ISO 8601). Default: now" },
                { "key": "interval", "value": "hour", "description": "Bucket interval: 'minute', '15minute', 'hour', '6hour', or 'day'. Default: 'hour'" },
                { "key": "vmrGuid", "value": "", "disabled": true, "description": "Filter by Virtual Model Runner GUID" }
              ]
            },
            "description": "Get aggregated request counts grouped by time buckets with success/failure breakdown. Returns time-bucketed data suitable for charting."
          }
        },
        {
          "name": "Get Request History Entry",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1.0/requesthistory/{{requestHistoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1.0", "requesthistory", "{{requestHistoryId}}"]
            },
            "description": "Get request history entry metadata by ID."
          }
        },
        {
          "name": "Get Request History Detail",
          "request": {
            "method": "GET",
            "url": {
