        },
        {
          "name": "Restore Backup",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1.0/backup/restore",
              "host": ["{{baseUrl}}"],
              "path": ["v1.0", "backup", "restore"]
            },
            "description": "Restore from a JSON backup. Pass the backup JSON as the request body."
          }
        },
        {
          "name": "Validate Backup",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
